#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$ROOT"

# The ecosystem runs Ruby 3.3 (brew ruby@3.3). Rails 8.1 — which the gemspec now
# allows (>= 7.2, < 8.2) — requires Ruby >= 3.2, so prefer the 3.3 toolchain when
# present rather than the retired 3.1 line.
if [ -d /opt/homebrew/opt/ruby@3.3/bin ]; then
  export PATH="/opt/homebrew/opt/ruby@3.3/bin:/opt/homebrew/lib/ruby/gems/3.3.0/bin:$PATH"
fi

build=0
case "${1:-}" in
  "")
    ;;
  "--build")
    build=1
    ;;
  "--list")
    # Print the run list (the tree-glob manifest minus RELEASE_CHECK_HIDE) and
    # exit — lets test/lib/release_check_guard_test.rb assert the runner
    # enumerates from the same source the guard checks against.
    exec ruby bin/suite-guard --run-list
    ;;
  *)
    echo "Usage: bin/release-check [--build|--list]" >&2
    exit 64
    ;;
esac

# Explicit XXXXXX template: portable across BSD mktemp (macOS, where a bare
# `-t prefix` works) and GNU mktemp (ubuntu-latest CI, which rejects a template
# with too few X's). Getting this wrong reddens the CI lane but not local runs.
suite_log="$(mktemp "${TMPDIR:-/tmp}/studio-engine-suite.XXXXXX")"
trap 'rm -f "$suite_log"' EXIT

echo "Ruby: $(ruby -v)"
echo "Studio Engine: $(ruby -Ilib -e 'require "studio/version"; print Studio::VERSION')"

for file in \
  lib/studio.rb \
  lib/studio/engine.rb \
  lib/studio/email.rb \
  lib/studio/email_smoke.rb \
  lib/studio/mail_transport.rb \
  app/helpers/studio_email_delivery_helper.rb \
  app/controllers/concerns/studio/impersonation.rb \
  app/controllers/magic_links_controller.rb \
  app/controllers/studio/local_emails_controller.rb \
  app/models/studio/email_delivery.rb \
  app/jobs/studio/email_delivery_job.rb \
  lib/tasks/studio_email.rake \
  lib/tasks/studio_ses.rake \
  studio-engine.gemspec
do
  ruby -c "$file"
done

ruby -rerb -e 'ARGV.each { |path| ERB.new(File.read(path)).src }; puts "Banner ERB ok."' \
  app/views/studio/banners/_app_banner.html.erb \
  app/views/studio/banners/_button.html.erb \
  app/views/studio/banners/_dev_mode_button.html.erb \
  app/views/studio/banners/_email_status_button.html.erb \
  app/views/studio/banners/_environment.html.erb \
  app/views/studio/banners/_impersonation.html.erb

# The suite enumerates by GLOB, not by curated list: bin/suite-guard --run-list
# derives every test/**/*_test.rb from the tree, so a new test file is included
# by construction. Review round 2 of this lane caught a curated list running 25
# of 26 files — with the guard structurally unable to see the miss. There is no
# list left to drift.
#
# RELEASE_CHECK_HIDE (colon-separated paths) removes files from the RUN list
# only — never from the guard's manifest below — so hiding a file always
# reddens the run. It is a mutation hook to prove the guard trips, not a way
# to skip a failing test.
while IFS= read -r test_file; do
  echo "== $test_file"
  echo "== $test_file" >> "$suite_log"
  ruby -Itest "$test_file" 2>&1 | tee -a "$suite_log"
done < <(ruby bin/suite-guard --run-list)

# Gate the suite on EVIDENCE, not on the exit status alone. bin/suite-guard
# re-globs the tree independently of the run list and fails if any test file
# in the tree never ran (the round-2 blocker class), if a file was announced
# but produced no minitest summary (it ran nothing), if it ran zero tests, or
# if it skipped one — a skip reads as a pass. Unit-tested, mutation-first, in
# test/lib/release_check_guard_test.rb.
ruby bin/suite-guard "$suite_log"

if [ "$build" -eq 1 ]; then
  version="$(ruby -Ilib -e 'require "studio/version"; print Studio::VERSION')"
  output_dir="/tmp/studio-engine-release-check"
  output="$output_dir/studio-engine-${version}.gem"

  mkdir -p "$output_dir"
  rm -f "$output"
  gem build studio-engine.gemspec --output "$output"
  gem specification "$output" name
  gem specification "$output" version
  gem specification "$output" dependencies
  echo "Built $output"
fi

echo "Release check complete."
